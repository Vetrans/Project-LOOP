# Same local MongoDB the Node backend uses — this service reads Feedback
# and Theme documents directly (read-only) to answer Ask LOOP questions.
MONGODB_URI=mongodb://127.0.0.1:27017/loop

# Optional. Without this, Ask LOOP falls back to a deterministic local
# summary (still cites real retrieved items — just isn't Claude-written).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

PORT=8000
